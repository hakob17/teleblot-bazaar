generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String    @id @default(uuid())
  telegramId   String    @unique
  username     String?
  tonAddress   String?
  starsBalance Int       @default(0)
  tonBalance   Float     @default(0)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  gamesPlayed   Player[]
  transactions  Transaction[]
}

model Match {
  id            String    @id @default(uuid())
  status        MatchStatus @default(WAITING)
  betAmount     Float
  betCurrency   Currency
  stateJson     String?   @db.Text   // To store the detailed Bazzar Blot game state securely on backend
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  players       Player[]
  transactions  Transaction[]
}

model Player {
  id        String   @id @default(uuid())
  userId    String
  matchId   String
  seatIndex Int      // 0, 1, 2, or 3
  isReady   Boolean  @default(false)
  joinedAt  DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id])
  match     Match    @relation(fields: [matchId], references: [id])

  @@unique([matchId, seatIndex])
  @@unique([matchId, userId])
}

model Transaction {
  id        String   @id @default(uuid())
  userId    String
  matchId   String?
  amount    Float
  currency  Currency
  type      TxType
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id])
  match     Match?   @relation(fields: [matchId], references: [id])
}

enum MatchStatus {
  WAITING
  AUCTION
  PLAYING
  FINISHED
  CANCELLED
}

enum Currency {
  TON
  STARS
}

enum TxType {
  DEPOSIT
  WITHDRAWAL
  BET_PLACED
  WINNINGS
  COMMISSION
}
